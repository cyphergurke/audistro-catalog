{
  "service": "audistro-catalog",
  "keys": [
    { "key": "AUDISTRO_ENV", "required_in_prod": true, "pattern": "^(prod|dev|test)$", "redact": false },
    { "key": "AUDICATALOG_DB_PATH", "required_in_prod": true, "pattern": "^/.+", "redact": false },
    { "key": "CATALOG_PROVIDER_TARGETS", "required_in_prod": true, "pattern": "(?s)^.{1,}$", "redact": false },
    { "key": "FAP_ADMIN_TOKEN", "required_in_prod": true, "pattern": "(?s)^.{1,}$", "redact": true }
  ]
}
